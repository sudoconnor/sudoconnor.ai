---
import BaseLayout from '@/layouts/BaseLayout.astro';
import AsciiLogo from '@/components/AsciiLogo.astro';
import { SITE } from '@/data/site';
---

<BaseLayout title={`${SITE.title} | ${SITE.tagline}`} description={SITE.description}>
  <section class="flex min-h-[calc(100vh-4rem)] flex-col items-center justify-center px-6">
    <AsciiLogo />

    <div class="mt-10 flex gap-4 opacity-0" id="cta-buttons">
      <a
        href="/about"
        class="rounded-lg border border-sc-blue bg-sc-blue/10 px-6 py-2.5 font-medium text-sc-blue transition-all hover:bg-sc-blue/20"
      >
        About Me
      </a>
      <a
        href="/blog"
        class="rounded-lg border border-sc-bg-surface px-6 py-2.5 font-medium text-sc-text-muted transition-all hover:border-sc-blue/30 hover:text-sc-text"
      >
        Read the Blog
      </a>
    </div>
  </section>

  <!-- Brief intro section -->
  <section class="mx-auto max-w-3xl px-6 pb-20">
    <p class="mb-10 text-center text-lg text-sc-text-muted">
      Staff DevSecOps Engineer. 12+ years across commercial and defense.
      Currently shipping AI platforms for the DoD at <strong class="text-sc-text">Raft</strong>.
    </p>

    <div class="grid gap-6 sm:grid-cols-3">
      <div class="rounded-lg border border-sc-blue/10 bg-sc-bg-card p-6">
        <div class="mb-3 font-mono text-sm text-sc-blue">01 // Platform</div>
        <p class="text-sm text-sc-text-muted">
          Kubernetes clusters across classification levels. Air-gapped, edge, cloud. 500+ nodes, 5 regions, zero excuses.
        </p>
      </div>
      <div class="rounded-lg border border-sc-blue/10 bg-sc-bg-card p-6">
        <div class="mb-3 font-mono text-sm text-sc-blue">02 // Security</div>
        <p class="text-sm text-sc-text-muted">
          If your pipeline can ship insecure code, your pipeline is the vulnerability. Security is architecture, not a checkbox.
        </p>
      </div>
      <div class="rounded-lg border border-sc-blue/10 bg-sc-bg-card p-6">
        <div class="mb-3 font-mono text-sm text-sc-blue">03 // Agents</div>
        <p class="text-sm text-sc-text-muted">
          The engineers who learn to wield agents will build things the rest of the industry can't even scope. That's where I'm headed.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // Delay CTA buttons until after ASCII animation
  setTimeout(() => {
    const cta = document.getElementById('cta-buttons');
    cta?.classList.remove('opacity-0');
    cta?.classList.add('animate-fade-in');
  }, 2000);
</script>
