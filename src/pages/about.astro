---
import BaseLayout from '@/layouts/BaseLayout.astro';

const skills = {
  'Infrastructure': ['Kubernetes', 'Terraform', 'Docker', 'Ansible', 'Helm'],
  'Cloud': ['AWS', 'Azure', 'GCP'],
  'Languages': ['Python', 'Go', 'TypeScript', 'Bash', 'HCL'],
  'Security': ['DevSecOps', 'SAST/DAST', 'Policy as Code', 'RMF/STIG', 'Secret Management'],
  'CI/CD': ['GitHub Actions', 'GitLab CI', 'ArgoCD', 'Jenkins'],
  'AI & Agents': ['Multi-Agent Systems', 'Agentic Workflows', 'LLM Integration', 'Prompt Engineering'],
  'Observability': ['Prometheus', 'Grafana', 'Datadog', 'ELK Stack'],
};
---

<BaseLayout title="About | SudoConnor" description="Platform engineer and DevSecOps practitioner who builds what matters.">
  <section class="mx-auto max-w-3xl px-6 py-12">
    <!-- Intro -->
    <div class="mb-12">
      <h1 class="mb-2 font-mono text-sm text-sc-blue">$ whoami</h1>
      <h2 class="mb-6 text-3xl font-bold sm:text-4xl">Connor</h2>
      <div class="space-y-4 text-lg leading-relaxed text-sc-text-muted">
        <p>
          I'm a Platform Engineer and DevSecOps practitioner who builds secure,
          mission-critical infrastructure — the kind of work where "move fast and
          break things" gets replaced with "move fast and break nothing."
        </p>
        <p>
          I believe the best engineering isn't measured by lines of code shipped, but
          by impact delivered. I'm drawn to the idea that agentic AI and multi-agent
          systems aren't here to replace engineers — they're here to unleash them.
          Human intent drives the destination. Agents accelerate the journey. The backlog
          shouldn't be a bottleneck when bandwidth is no longer the constraint.
        </p>
        <p>
          I work at the intersection of platform engineering, security, and AI —
          building hardened pipelines, automating compliance, and experimenting with
          agentic workflows that turn what used to take weeks into hours. Security
          isn't a phase you bolt on at the end — it's architecture.
        </p>
      </div>
    </div>

    <!-- Skills -->
    <div class="mb-12">
      <h2 class="mb-6 font-mono text-sm text-sc-blue">$ cat skills.json</h2>
      <div class="grid gap-6 sm:grid-cols-2">
        {Object.entries(skills).map(([category, items]) => (
          <div>
            <h3 class="mb-3 text-sm font-semibold uppercase tracking-wider text-sc-text-muted">
              {category}
            </h3>
            <div class="flex flex-wrap gap-2">
              {items.map((skill) => (
                <span class="rounded-full border border-sc-blue/20 bg-sc-blue/10 px-3 py-1 text-xs font-medium text-sc-blue">
                  {skill}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Principles -->
    <div>
      <h2 class="mb-6 font-mono text-sm text-sc-blue">$ cat principles.md</h2>
      <ul class="space-y-3 text-sc-text-muted">
        <li class="flex items-start gap-3">
          <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-sc-blue"></span>
          <span><strong class="text-sc-text">Results over busywork.</strong> The goal isn't more code — it's the right result, verified and delivered.</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-sc-blue"></span>
          <span><strong class="text-sc-text">Security is architecture, not a phase.</strong> Baked into every layer, every pipeline, every deploy.</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-sc-blue"></span>
          <span><strong class="text-sc-text">Agents are allies, not replacements.</strong> Human intent drives the destination. AI accelerates the journey.</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-sc-blue"></span>
          <span><strong class="text-sc-text">Verified reality is the only truth.</strong> If you can't prove what you delivered matches what you intended, it doesn't count.</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-sc-blue"></span>
          <span><strong class="text-sc-text">Ship fast, but ship safe.</strong> Fast feedback loops with guardrails — speed without recklessness.</span>
        </li>
      </ul>
    </div>
  </section>
</BaseLayout>
