---
import BaseLayout from '@/layouts/BaseLayout.astro';

const skills = {
  'Container & Orchestration': ['Kubernetes (CKA)', 'Docker', 'Helm', 'Kustomize', 'containerd', 'Podman', 'Harbor'],
  'Cloud & Infrastructure': ['AWS', 'GCP', 'Azure', 'OpenStack', 'Proxmox', 'Bare Metal'],
  'IaC & Config': ['Terraform', 'Ansible', 'Salt', 'Vault'],
  'CI/CD': ['GitHub Actions', 'GitLab CI', 'Jenkins', 'ArgoCD', 'Flux'],
  'Security': ['DevSecOps', 'Keycloak', 'RBAC', 'SSL/TLS', 'Air-Gapped Delivery'],
  'Languages': ['Python', 'Go', 'Bash', 'HCL', 'TypeScript'],
  'Observability': ['Prometheus', 'Grafana', 'Datadog', 'ELK Stack', 'Loki'],
  'AI & Agents': ['Multi-Agent Systems', 'Agentic Workflows', 'LLM Integration'],
};
---

<BaseLayout title="About | SudoConnor" description="Staff DevSecOps Engineer with 12+ years building infrastructure for defense and enterprise systems.">
  <section class="mx-auto max-w-3xl px-6 py-12">
    <!-- Intro -->
    <div class="mb-12">
      <h1 class="mb-2 font-mono text-sm text-sc-blue">$ whoami</h1>
      <h2 class="mb-6 text-3xl font-bold sm:text-4xl">Connor Meehan</h2>
      <div class="space-y-4 text-lg leading-relaxed text-sc-text-muted">
        <p>
          Staff DevSecOps Engineer with 12+ years building infrastructure and leading
          teams for defense and enterprise systems. I ship AI-powered platforms across
          air-gapped, edge, and cloud environments where failure isn't an option —
          the kind of work where security isn't bolted on at the end, it's the architecture.
        </p>
        <p>
          Currently at <strong class="text-sc-text">Raft</strong>, leading DevSecOps
          for AI data platforms serving SOCOM and CENTCOM across multiple classification levels. Before
          that, I deployed container platforms at IBM/BoxBoat, reduced server provisioning
          from days to minutes at Hivelocity, and configured HA clusters spanning 500+ nodes
          across 5 global regions.
        </p>
        <p>
          I believe the best engineering isn't measured by lines of code shipped, but by
          impact delivered. I'm drawn to agentic AI and multi-agent systems — not as
          replacements for engineers, but as force multipliers. Human intent sets the
          direction. Agents accelerate the journey. The backlog shouldn't be a bottleneck
          when bandwidth is no longer the constraint.
        </p>
      </div>
    </div>

    <!-- Credentials -->
    <div class="mb-12 flex flex-wrap gap-3">
      <span class="rounded-full border border-sc-accent-green/30 bg-sc-accent-green/10 px-3 py-1 text-xs font-medium text-sc-accent-green">
        TS/SCI Cleared
      </span>
      <span class="rounded-full border border-sc-blue/30 bg-sc-blue/10 px-3 py-1 text-xs font-medium text-sc-blue">
        CKA Certified
      </span>
      <span class="rounded-full border border-sc-blue/30 bg-sc-blue/10 px-3 py-1 text-xs font-medium text-sc-blue">
        Security+ Certified
      </span>
      <span class="rounded-full border border-sc-text-muted/30 bg-sc-text-muted/10 px-3 py-1 text-xs font-medium text-sc-text-muted">
        Tampa, FL
      </span>
    </div>

    <!-- Skills -->
    <div class="mb-12">
      <h2 class="mb-6 font-mono text-sm text-sc-blue">$ cat skills.json</h2>
      <div class="grid gap-6 sm:grid-cols-2">
        {Object.entries(skills).map(([category, items]) => (
          <div>
            <h3 class="mb-3 text-sm font-semibold uppercase tracking-wider text-sc-text-muted">
              {category}
            </h3>
            <div class="flex flex-wrap gap-2">
              {items.map((skill) => (
                <span class="rounded-full border border-sc-blue/20 bg-sc-blue/10 px-3 py-1 text-xs font-medium text-sc-blue">
                  {skill}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Principles -->
    <div>
      <h2 class="mb-6 font-mono text-sm text-sc-blue">$ cat principles.md</h2>
      <ul class="space-y-3 text-sc-text-muted">
        <li class="flex items-start gap-3">
          <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-sc-blue"></span>
          <span><strong class="text-sc-text">Move fast and break things.</strong> Momentum beats perfection. You learn more from what breaks than from what you were afraid to touch.</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-sc-blue"></span>
          <span><strong class="text-sc-text">One line deleted beats ten lines written.</strong> If you didn't break something, you probably didn't delete enough.</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-sc-blue"></span>
          <span><strong class="text-sc-text">Results over solutions.</strong> Nobody cares how clever the architecture is if it doesn't ship. Solve the problem, prove it works, move on.</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-sc-blue"></span>
          <span><strong class="text-sc-text">Security is architecture, not a checkbox.</strong> If your pipeline can ship insecure code, your pipeline is the vulnerability.</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-sc-blue"></span>
          <span><strong class="text-sc-text">Agents will replace engineers who don't use them.</strong> The tools are here. Learn to wield them or get left behind.</span>
        </li>
      </ul>
    </div>
  </section>
</BaseLayout>
