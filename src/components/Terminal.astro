---
---

<!-- Desktop: bottom panel -->
<div
  id="terminal-panel"
  class="fixed inset-x-0 bottom-0 z-50 hidden max-sm:hidden"
>
  <div class="mx-auto max-w-3xl px-4 pb-4">
    <div class="overflow-hidden rounded-lg border border-sc-blue/20 bg-sc-bg-card shadow-2xl shadow-sc-blue-glow">
      <!-- Title bar -->
      <div class="flex items-center justify-between border-b border-sc-blue/10 px-4 py-2">
        <div class="flex items-center gap-2">
          <span class="h-3 w-3 rounded-full bg-red-500/80"></span>
          <span class="h-3 w-3 rounded-full bg-sc-accent-yellow/80"></span>
          <span class="h-3 w-3 rounded-full bg-sc-accent-green/80"></span>
        </div>
        <span class="font-mono text-xs text-sc-text-muted">sudoconnor</span>
        <button class="terminal-close-btn p-1 text-sc-text-muted transition-colors hover:text-sc-text" aria-label="Close terminal">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="2" y1="2" x2="12" y2="12" /><line x1="12" y1="2" x2="2" y2="12" />
          </svg>
        </button>
      </div>
      <div id="terminal-output-desktop" class="h-64 overflow-y-auto p-4 font-mono text-sm leading-relaxed">
        <div class="text-sc-text-muted">Welcome to SudoConnor terminal. Type <span class="text-sc-accent-green">help</span> for available commands.</div>
      </div>
      <div class="flex items-center border-t border-sc-blue/10 px-4 py-2 font-mono text-sm">
        <span class="shrink-0 text-sc-accent-green">$</span><span class="shrink-0 text-sc-text-muted">&nbsp;</span>
        <input
          id="terminal-input-desktop"
          type="text"
          class="terminal-input min-w-0 flex-1 border-none bg-transparent text-sc-text outline-none"
          autocomplete="off"
          autocapitalize="off"
          spellcheck="false"
        />
      </div>
    </div>
  </div>
</div>

<!-- Mobile: full screen overlay -->
<div
  id="terminal-panel-mobile"
  class="fixed inset-0 z-50 hidden sm:hidden"
  style="height: 100dvh;"
>
  <div class="flex h-full flex-col bg-sc-bg-card">
    <!-- Title bar -->
    <div class="flex shrink-0 items-center justify-between border-b border-sc-blue/10 px-4 py-3">
      <div class="flex items-center gap-2">
        <span class="h-3 w-3 rounded-full bg-red-500/80"></span>
        <span class="h-3 w-3 rounded-full bg-sc-accent-yellow/80"></span>
        <span class="h-3 w-3 rounded-full bg-sc-accent-green/80"></span>
        <span class="ml-2 font-mono text-xs text-sc-text-muted">sudoconnor</span>
      </div>
      <button class="terminal-close-btn rounded-md px-3 py-1.5 text-sm text-sc-text-muted transition-colors hover:text-sc-text" aria-label="Close terminal">
        ✕ close
      </button>
    </div>

    <!-- Output area -->
    <div id="terminal-output-mobile" class="min-h-0 flex-1 overflow-y-auto p-4 font-mono text-sm leading-relaxed">
      <div class="text-sc-text-muted">Welcome to SudoConnor terminal. Type <span class="text-sc-accent-green">help</span> for available commands.</div>
    </div>

    <!-- Input line - pinned to bottom -->
    <div class="shrink-0 border-t border-sc-blue/10 bg-sc-bg px-4 py-3 font-mono text-base">
      <div class="flex items-center">
        <span class="shrink-0 text-sc-accent-green">$</span><span class="shrink-0 text-sc-text-muted">&nbsp;</span>
        <input
          id="terminal-input-mobile"
          type="text"
          class="terminal-input min-w-0 flex-1 border-none bg-transparent text-base text-sc-text outline-none"
          autocomplete="off"
          autocapitalize="off"
          spellcheck="false"
          enterkeyhint="send"
        />
      </div>
    </div>
  </div>
</div>

<script>
  const desktopPanel = document.getElementById('terminal-panel')!;
  const mobilePanel = document.getElementById('terminal-panel-mobile')!;
  const desktopOutput = document.getElementById('terminal-output-desktop')!;
  const mobileOutput = document.getElementById('terminal-output-mobile')!;
  const desktopInput = document.getElementById('terminal-input-desktop') as HTMLInputElement;
  const mobileInput = document.getElementById('terminal-input-mobile') as HTMLInputElement;
  const toggleBtn = document.getElementById('terminal-toggle');

  const history: string[] = [];
  let historyIndex = -1;

  function isMobile() {
    return window.matchMedia('(max-width: 639px)').matches;
  }

  function getActivePanel() { return isMobile() ? mobilePanel : desktopPanel; }
  function getActiveOutput() { return isMobile() ? mobileOutput : desktopOutput; }
  function getActiveInput() { return isMobile() ? mobileInput : desktopInput; }

  function toggleTerminal() {
    const panel = getActivePanel();
    const input = getActiveInput();
    // Hide both panels first
    desktopPanel.classList.add('hidden');
    mobilePanel.classList.add('hidden');

    if (panel.classList.contains('hidden')) {
      // Was hidden, now show
      panel.classList.remove('hidden');
      input.focus();
      // On mobile, scroll to keep input visible when keyboard opens
      if (isMobile()) {
        setTimeout(() => input.scrollIntoView({ block: 'end' }), 300);
      }
    }
    // else: both are now hidden (closed)
  }

  function appendLine(text: string, className = '') {
    // Append to both outputs so they stay in sync
    [desktopOutput, mobileOutput].forEach(output => {
      const div = document.createElement('div');
      div.className = 'whitespace-pre-wrap break-words' + (className ? ' ' + className : '');
      div.innerHTML = text;
      output.appendChild(div);
      output.scrollTop = output.scrollHeight;
    });
  }

  function appendPrompt(cmd: string) {
    appendLine(
      `<span class="text-sc-accent-green">$</span> ${escapeHtml(cmd)}`
    );
  }

  function escapeHtml(s: string): string {
    return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }

  const commands: Record<string, (args: string[]) => string> = {
    help: () =>
      `<span class="text-sc-blue">Available commands:</span>
  <span class="text-sc-accent-green">whoami</span>      Who is Connor?
  <span class="text-sc-accent-green">about</span>       Quick bio
  <span class="text-sc-accent-green">skills</span>      Technical skills
  <span class="text-sc-accent-green">projects</span>    Notable projects
  <span class="text-sc-accent-green">contact</span>     Get in touch
  <span class="text-sc-accent-green">blog</span>        Latest posts
  <span class="text-sc-accent-green">neofetch</span>    System info
  <span class="text-sc-accent-green">cat</span>         Read a file
  <span class="text-sc-accent-green">ls</span>          List pages
  <span class="text-sc-accent-green">clear</span>       Clear terminal
  <span class="text-sc-accent-green">exit</span>        Close terminal`,

    whoami: () =>
      'Connor Meehan // Staff DevSecOps Engineer @ Raft',

    about: () =>
      `12+ years building infrastructure across commercial and defense.
Leading DevSecOps for AI platforms serving DoD customers I probably can't talk about.
<span class="text-sc-text-muted">→ <a href="/about" class="text-sc-blue underline">/about</a></span>`,

    skills: () =>
      `<span class="text-sc-blue">Containers:</span>  K8s, Docker, Helm, Harbor
<span class="text-sc-blue">Cloud:</span>       AWS, GCP, Azure, Bare Metal
<span class="text-sc-blue">IaC:</span>         Terraform, Ansible, Vault
<span class="text-sc-blue">CI/CD:</span>       Actions, GitLab, ArgoCD, Flux
<span class="text-sc-blue">Security:</span>    DevSecOps, Keycloak, RBAC
<span class="text-sc-blue">Languages:</span>   Python, Go, Bash, HCL, TS
<span class="text-sc-blue">AI:</span>          Agents, LLMs, Agentic Workflows`,

    projects: () =>
      `<span class="text-sc-accent-green">sudoconnor.ai</span>  This site
  <span class="text-sc-text-muted">More coming soon...</span>`,

    contact: () =>
      `<span class="text-sc-blue">GitHub:</span>    <a href="https://github.com/sudoconnor" class="text-sc-blue-light underline" target="_blank">sudoconnor</a>
<span class="text-sc-blue">LinkedIn:</span>  <a href="https://www.linkedin.com/in/meehan-connor" class="text-sc-blue-light underline" target="_blank">meehan-connor</a>`,

    blog: () =>
      `<a href="/blog/hello-world" class="text-sc-blue-light underline">Hello, World</a>
<span class="text-sc-text-muted">→ <a href="/blog" class="text-sc-blue underline">/blog</a></span>`,

    neofetch: () =>
      `<span class="text-sc-blue">connor</span>@<span class="text-sc-blue">sudoconnor.ai</span>
──────────────────────
<span class="text-sc-blue">Role:</span>      Staff DevSecOps @ Raft
<span class="text-sc-blue">XP:</span>        12+ years
<span class="text-sc-blue">Clearance:</span> TS/SCI
<span class="text-sc-blue">Certs:</span>     CKA, Security+
<span class="text-sc-blue">Location:</span>  Tampa, FL
<span class="text-sc-blue">Languages:</span> Python, Go, Bash, HCL
<span class="text-sc-blue">Nodes:</span>     500+ across 5 regions
<span class="text-sc-blue">Status:</span>    <span class="text-sc-accent-green">Shipping</span>`,

    ls: () =>
      `<span class="text-sc-blue">drwxr-xr-x</span>  home/
<span class="text-sc-blue">drwxr-xr-x</span>  about/
<span class="text-sc-blue">drwxr-xr-x</span>  blog/`,

    echo: (args) => args.length > 0 ? escapeHtml(args.join(' ')) : '',

    history: () => history.map((cmd, i) => `  ${i + 1}  ${escapeHtml(cmd)}`).join('\n'),

    clear: () => {
      desktopOutput.innerHTML = '';
      mobileOutput.innerHTML = '';
      return '';
    },

    exit: () => {
      toggleTerminal();
      return '';
    },

    sudo: (args) => {
      const full = args.join(' ');
      if (full.includes('rm -rf')) {
        return '<span class="text-sc-accent-yellow">I admire your courage, but no.</span>';
      }
      if (full.includes('make')) {
        return `<span class="text-sc-accent-green">[sudo] Building something awesome...</span>\nDone. ✓`;
      }
      return `<span class="text-sc-accent-yellow">Nice try.</span> You already have root.`;
    },

    cat: (args) => {
      if (args[0] === 'resume.txt') {
        return `<span class="text-sc-blue">Connor Meehan</span>
Staff DevSecOps Engineer
TS/SCI | CKA | Security+

<span class="text-sc-blue">Raft</span>       Staff DevSecOps  2024–Now
<span class="text-sc-blue">Raft</span>       Sr. DevSecOps    2023–2024
<span class="text-sc-blue">IBM</span>        Sr. DevOps / SA  2022–2023
<span class="text-sc-blue">Hivelocity</span> Sr. DevOps       2019–2022
<span class="text-sc-blue">Hivelocity</span> Jr. DevOps       2013–2019
<span class="text-sc-text-muted">→ <a href="/about" class="text-sc-blue underline">/about</a></span>`;
      }
      return `cat: ${escapeHtml(args[0] || '')}: No such file or directory`;
    },

    cd: (args) => {
      const target = args[0] || '~';
      if (['~', '/'].includes(target)) {
        window.location.href = '/';
        return '';
      }
      const pages: Record<string, string> = { about: '/about', blog: '/blog' };
      if (pages[target] || pages[target.replace('/', '')]) {
        window.location.href = pages[target] || pages[target.replace('/', '')];
        return '';
      }
      return `bash: cd: ${escapeHtml(target)}: No such file or directory`;
    },

    pwd: () => '/home/connor/sudoconnor.ai',

    date: () => new Date().toString(),

    uname: () => 'SudoConnor OS 1.0.0 x86_64',
  };

  function processCommand(raw: string) {
    const trimmed = raw.trim();
    if (!trimmed) return;

    history.push(trimmed);
    historyIndex = history.length;

    appendPrompt(trimmed);

    const parts = trimmed.split(/\s+/);
    const cmd = parts[0].toLowerCase();
    const args = parts.slice(1);

    const handler = commands[cmd];
    const result = handler ? handler(args) : `<span class="text-red-400">Command not found: ${escapeHtml(cmd)}</span>. Type <span class="text-sc-accent-green">help</span> for commands.`;

    if (result) appendLine(result);
  }

  // Input handling for both inputs
  function setupInput(inputEl: HTMLInputElement) {
    inputEl.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        processCommand(inputEl.value);
        inputEl.value = '';
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        if (historyIndex > 0) {
          historyIndex--;
          inputEl.value = history[historyIndex];
        }
      } else if (e.key === 'ArrowDown') {
        e.preventDefault();
        if (historyIndex < history.length - 1) {
          historyIndex++;
          inputEl.value = history[historyIndex];
        } else {
          historyIndex = history.length;
          inputEl.value = '';
        }
      } else if (e.key === 'Escape') {
        toggleTerminal();
      }
    });
  }

  setupInput(desktopInput);
  setupInput(mobileInput);

  // Toggle shortcuts
  document.addEventListener('keydown', (e) => {
    if (e.ctrlKey && e.key === '`') {
      e.preventDefault();
      toggleTerminal();
    }
  });

  // Close buttons
  document.querySelectorAll('.terminal-close-btn').forEach(btn => {
    btn.addEventListener('click', toggleTerminal);
  });
  toggleBtn?.addEventListener('click', toggleTerminal);
</script>
