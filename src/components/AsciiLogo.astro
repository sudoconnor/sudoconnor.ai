---
import { SITE } from '@/data/site';
---

<div class="flex flex-col items-center justify-center text-center">
  <!-- Large ASCII art for sm+ screens -->
  <pre
    id="ascii-logo"
    class="hidden select-none font-mono text-[0.45rem] leading-tight text-sc-blue glow-blue sm:block sm:text-xs md:text-sm lg:text-base"
    aria-label="SudoConnor"
  ></pre>

  <!-- Simple text for mobile -->
  <h1
    id="ascii-logo-mobile"
    class="font-mono text-3xl font-bold text-sc-blue glow-blue opacity-0 sm:hidden"
  >
    &gt;_ SudoConnor
  </h1>

  <p id="tagline" class="mt-6 max-w-md text-lg text-sc-text-muted opacity-0 sm:text-xl">
    {SITE.tagline}
  </p>

  <span id="cursor" class="ml-1 inline-block h-5 w-0.5 bg-sc-blue opacity-0"></span>
</div>

<script>
  const LOGO = `  ____            _        ____
 / ___| _   _  __| | ___  / ___|___  _ __  _ __   ___  _ __
 \\___ \\| | | |/ _\` |/ _ \\| |   / _ \\| '_ \\| '_ \\ / _ \\| '__|
  ___) | |_| | (_| | (_) | |__| (_) | | | | | | | (_) | |
 |____/ \\__,_|\\__,_|\\___/ \\____\\___/|_| |_|_| |_|\\___/|_|`;

  const logoEl = document.getElementById('ascii-logo');
  const mobileEl = document.getElementById('ascii-logo-mobile');
  const taglineEl = document.getElementById('tagline');
  const cursorEl = document.getElementById('cursor');

  function animateLogo() {
    if (!logoEl) return;

    const chars = LOGO.split('');
    let i = 0;
    const charsPerFrame = 4;

    function typeNext() {
      if (i < chars.length) {
        const end = Math.min(i + charsPerFrame, chars.length);
        logoEl.textContent += LOGO.slice(i, end);
        i = end;
        requestAnimationFrame(typeNext);
      } else {
        showTagline();
      }
    }

    requestAnimationFrame(typeNext);
  }

  function showTagline() {
    taglineEl?.classList.remove('opacity-0');
    taglineEl?.classList.add('animate-fade-in');
    cursorEl?.classList.remove('opacity-0');
    cursorEl?.classList.add('animate-blink');
  }

  // Mobile: just fade in
  if (mobileEl) {
    setTimeout(() => {
      mobileEl.classList.remove('opacity-0');
      mobileEl.classList.add('animate-fade-in');
      setTimeout(showTagline, 400);
    }, 200);
  }

  animateLogo();
</script>
