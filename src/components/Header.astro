---
import { NAV_LINKS } from '@/data/site';

const pathname = new URL(Astro.request.url).pathname;
---

<header class="fixed top-0 left-0 right-0 z-50 border-b border-sc-blue/10 bg-sc-bg/80 backdrop-blur-md">
  <nav class="mx-auto flex max-w-4xl items-center justify-between px-6 py-4">
    <a href="/" class="font-mono text-lg font-bold text-sc-blue transition-colors hover:text-sc-blue-light">
      &gt;_ SudoConnor
    </a>

    <!-- Desktop nav -->
    <ul class="hidden items-center gap-8 sm:flex">
      {NAV_LINKS.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              'font-medium transition-colors hover:text-sc-blue',
              pathname === link.href || (link.href !== '/' && pathname.startsWith(link.href))
                ? 'text-sc-blue'
                : 'text-sc-text-muted',
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Mobile hamburger -->
    <button
      id="mobile-menu-btn"
      class="text-sc-text-muted transition-colors hover:text-sc-blue sm:hidden"
      aria-label="Toggle menu"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="3" y1="6" x2="21" y2="6" />
        <line x1="3" y1="12" x2="21" y2="12" />
        <line x1="3" y1="18" x2="21" y2="18" />
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden border-t border-sc-blue/10 bg-sc-bg/95 backdrop-blur-md sm:hidden">
    <ul class="flex flex-col gap-1 px-6 py-4">
      {NAV_LINKS.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              'block rounded-lg px-4 py-2 font-medium transition-colors hover:bg-sc-bg-card hover:text-sc-blue',
              pathname === link.href || (link.href !== '/' && pathname.startsWith(link.href))
                ? 'text-sc-blue'
                : 'text-sc-text-muted',
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
